{
  "name": "Progress",
  "type": "object",
  "properties": {
    "user_id": { "type": "string", "description": "Owner of this progress record" },
    "lesson_id": { "type": "string", "description": "Id of the completed Lesson" },
    "track_code": { "type": "string" },
    "completed": { "type": "boolean", "default": false },
    "xp_earned": { "type": "number", "default": 0 },
    "completed_date": { "type": "string", "format": "date-time" }
  },
  "required": ["lesson_id"]
}